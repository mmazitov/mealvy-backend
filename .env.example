# .env.example — скопируйте в .env.local и заполните секреты

# ─── Database ───────────────────────────────────────────────
DATABASE_URL="mongodb+srv://user:pass@cluster.mongodb.net/mealvy"

# ─── JWT & Session ──────────────────────────────────────────
JWT_SECRET="change-me-in-production"
SESSION_SECRET="change-me-in-production"

# ─── Server ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Frontend URL (CORS + OAuth redirect) ───────────────────
# Dev:  http://localhost:5173
# Prod: https://mealvy.app
CLIENT_URL=http://localhost:5173

# ─── Cookie domain ──────────────────────────────────────────
# Dev:  не указывать (undefined = работает на localhost)
# Prod: .mealvy.app
# COOKIE_DOMAIN=.mealvy.app

# ─── OAuth — Google ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Dev:  http://localhost:4000/auth/google/callback
# Prod: https://api.mealvy.app/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ─── OAuth — GitHub ─────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# ─── OAuth — Facebook ───────────────────────────────────────
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:4000/auth/facebook/callback

# ─── Email (SMTP) ───────────────────────────────────────────
# Gmail: smtp.gmail.com, port 587, secure=false
# Для Gmail потрібен App Password: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM_NAME=Mealvy
EMAIL_FROM=noreply@mealvy.app
