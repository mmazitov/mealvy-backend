// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

type Ingredient {
  name      String
  amount    String
  productId String? @db.ObjectId
}

model Dish {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  description   String?
  imageUrl      String?
  category      String?
  prepTime      Int?
  servings      Int?
  calories      Int?
  protein       Float?
  fat           Float?
  carbs         Float?
  ingredients   Ingredient[]
  instructions  String[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  userId        String        @db.ObjectId
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  favoriteByIds String[]      @db.ObjectId
  favoriteBy    User[]        @relation("UserFavoriteDishes", fields: [favoriteByIds], references: [id])
  plannerItems  PlannerItem[]
}

model Product {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  category      String?
  imageUrl      String?
  calories      Int?
  fat           Float?
  carbs         Float?
  protein       Float?
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  favoriteByIds String[] @db.ObjectId
  favoriteBy    User[]   @relation("UserFavoriteProducts", fields: [favoriteByIds], references: [id])
}

model User {
  id                 String             @id @default(auto()) @map("_id") @db.ObjectId
  email              String?            @unique
  name               String?
  password           String?
  phone              String?
  avatar             String?
  role               Role               @default(USER)
  accounts           Account[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  diet               String?
  allergy            String[]
  dislike            String[]
  dishes             Dish[]
  favoriteDishIds    String[]           @db.ObjectId
  favoriteDishes     Dish[]             @relation("UserFavoriteDishes", fields: [favoriteDishIds], references: [id])
  products           Product[]
  favoriteProductIds String[]           @db.ObjectId
  favoriteProducts   Product[]          @relation("UserFavoriteProducts", fields: [favoriteProductIds], references: [id])
  plannerItems       PlannerItem[]
  savedMenus         SavedMenu[]
  family             FamilyMember[]     @relation("UserFamily")
  familyMembers      FamilyMember[]     @relation("FamilyMembers")
  sentInvitations    FamilyInvitation[] @relation("SentInvitations")
}

model FamilyMember {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation("UserFamily", fields: [userId], references: [id], onDelete: Cascade)
  memberId  String   @db.ObjectId
  member    User     @relation("FamilyMembers", fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, memberId])
}

model FamilyInvitation {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  inviterId    String           @db.ObjectId
  inviter      User             @relation("SentInvitations", fields: [inviterId], references: [id], onDelete: Cascade)
  inviteeEmail String
  status       InvitationStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  expiresAt    DateTime

  @@unique([inviterId, inviteeEmail])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model PlannerItem {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  userId      String     @db.ObjectId
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  dishId      String     @db.ObjectId
  dish        Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)
  savedMenuId String?    @db.ObjectId
  savedMenu   SavedMenu? @relation(fields: [savedMenuId], references: [id], onDelete: Cascade)
  date        DateTime
  mealTime    MealTime
  createdAt   DateTime   @default(now())
}

model SavedMenu {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  userId     String        @db.ObjectId
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  startDate  DateTime
  endDate    DateTime
  weekNumber Int
  items      PlannerItem[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

enum MealTime {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model Account {
  id                String @id @default(auto()) @map("_id") @db.ObjectId
  userId            String @db.ObjectId
  provider          String
  providerAccountId String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

enum Role {
  USER
  ADMIN
}
